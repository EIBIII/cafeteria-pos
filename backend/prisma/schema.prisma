// prisma/schema.prisma
// Ejecutar: npx prisma migrate dev --name add_menu_config_models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles y permisos ──────────────────────────────────────────────────────────
model Role {
  id               String   @id              // slug: "admin", "cashier"
  label            String
  color            String   @default("blue")
  allowedViews     String[]                  // ["pos","orders","account"]
  requiresCashCut  Boolean  @default(false)
  createdAt        DateTime @default(now())

  users            User[]
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?  @unique
  phone     String?
  password  String                            // hash bcrypt
  active    Boolean  @default(true)
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  sales     Sale[]
  cashCuts  CashCut[]
}

// ── Catálogo de productos ─────────────────────────────────────────────────────
model Category {
  id       String    @id              // "hot", "cold", "food"
  name     String
  icon     String    @default("☕")
  position Int       @default(0)

  products Product[]
}

model Product {
  id         Int       @id @default(autoincrement())
  name       String
  price      Float
  image      String    @default("☕")
  active     Boolean   @default(true)
  categoryId String
  category   Category  @relation(fields: [categoryId], references: [id])
  createdAt  DateTime  @default(now())

  // Modificadores aplicables a este producto (relación many-to-many)
  modifierGroups  ProductModifierGroup[]
  recipe          RecipeIngredient[]
  orderItems      OrderItem[]
}

// ── Sistema de Modificadores Dinámicos ───────────────────────────────────────
// Un "ModifierGroup" es una categoría de personalización: Tamaño, Leche,
// Endulzante, Temperatura, Cobertura, etc.
// Se crea desde la pantalla de Configuración de Menú y se puede asignar
// a uno o varios productos.

model ModifierGroup {
  id           Int        @id @default(autoincrement())
  name         String                          // "Tamaño", "Endulzante"
  inputType    String     @default("single")   // "single" | "multi"
  required     Boolean    @default(false)
  position     Int        @default(0)
  color        String     @default("amber")    // badge color: amber, blue, green, violet, rose, cyan, orange, indigo
  appliesTo    String[]   @default([])         // IDs de categorías donde aplica. Vacío = todas
  kind         String     @default("custom")   // "size" | "milk" | "extra" | "custom"
  createdAt    DateTime   @default(now())

  options      ModifierOption[]
  products     ProductModifierGroup[]
}

model ModifierOption {
  id          Int           @id @default(autoincrement())
  name        String                            // "Grande", "Stevia"
  extraPrice  Float         @default(0)
  position    Int           @default(0)
  groupId     Int
  group       ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Referencia opcional a inventario (para descontar automáticamente)
  inventoryItemId Int?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  orderItemModifiers OrderItemModifier[]
}

// Tabla pivote: qué grupos de modificadores tiene cada producto
model ProductModifierGroup {
  productId       Int
  modifierGroupId Int
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([productId, modifierGroupId])
}

// ── Inventario ────────────────────────────────────────────────────────────────
model InventoryItem {
  id           Int       @id @default(autoincrement())
  name         String
  quantity     Float
  unit         String                          // "g", "ml", "pz"
  minStock     Float     @default(0)
  lastRestocked DateTime?
  updatedAt    DateTime  @updatedAt

  recipe       RecipeIngredient[]
  modifierOptions ModifierOption[]
}

model RecipeIngredient {
  id              Int           @id @default(autoincrement())
  productId       Int
  inventoryItemId Int
  quantity        Float
  unit            String?

  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@unique([productId, inventoryItemId])
}

// ── Ventas ────────────────────────────────────────────────────────────────────
model Sale {
  id              Int        @id @default(autoincrement())
  orderNumber     Int        @unique @default(autoincrement())
  date            DateTime   @default(now())
  subtotal        Float
  tax             Float
  total           Float
  customerName    String?
  customerEmail   String?
  emailSent       Boolean    @default(false)   // ← si ya se envió el ticket
  userId          Int
  user            User       @relation(fields: [userId], references: [id])

  items           OrderItem[]
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  quantity    Int
  unitPrice   Float
  subtotal    Float
  saleId      Int
  productId   Int
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  // Modificadores seleccionados para este ítem
  modifiers   OrderItemModifier[]
}

model OrderItemModifier {
  id               Int            @id @default(autoincrement())
  orderItemId      Int
  modifierOptionId Int
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id])
}

// ── Cortes de caja ────────────────────────────────────────────────────────────
model CashCut {
  id            Int      @id @default(autoincrement())
  date          DateTime @default(now())
  loginTime     DateTime
  salesCount    Int
  totalSales    Float
  expectedCash  Float
  actualCash    Float
  difference    Float
  notes         String?
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
}
